<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:model="clr-namespace:Copilot.Sw.Models"
    xmlns:templateSelector="clr-namespace:Copilot.Sw.TemplateSelector"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/Copilot.Sw;component/Themes/Icons.xaml" />
    </ResourceDictionary.MergedDictionaries>
    <templateSelector:MessageTemplateSelector x:Key="MessageTemplateSelector">
        <templateSelector:MessageTemplateSelector.AskDataTemplate>
            <DataTemplate DataType="model:AskMessage">
                <Border
                    MaxWidth="320"
                    Margin="40,6,8,6"
                    Padding="10,8"
                    HorizontalAlignment="Right"
                    Background="#2563EB"
                    CornerRadius="12,12,2,12">
                    <TextBlock
                        FontSize="13"
                        Foreground="White"
                        Text="{Binding Content}"
                        TextWrapping="Wrap" />
                </Border>
            </DataTemplate>
        </templateSelector:MessageTemplateSelector.AskDataTemplate>
        <templateSelector:MessageTemplateSelector.AnswerDataTemplate>
            <DataTemplate DataType="model:AnswerMessage">
                <Grid Margin="8,6,40,6" HorizontalAlignment="Left">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="28" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Image
                        Width="22"
                        Height="22"
                        VerticalAlignment="Top"
                        Source="{StaticResource CopilotDrawingImage}" />
                    <Border
                        Grid.Column="1"
                        Margin="6,0,0,0"
                        Padding="10,8"
                        Background="White"
                        BorderBrush="#19000000"
                        BorderThickness="1"
                        CornerRadius="12,12,12,2">
                        <StackPanel>
                            <TextBlock
                                FontSize="13"
                                Text="{Binding Content}"
                                TextWrapping="Wrap" />
                            <!--  P5: per-step status — every native KernelFunction the model invoked this turn.  -->
                            <ItemsControl
                                Margin="0,6,0,0"
                                ItemsSource="{Binding ToolCalls}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="model:ToolCallEntry">
                                        <Border
                                            Margin="0,2,0,0"
                                            Padding="6,3"
                                            Background="#F5F7FA"
                                            BorderBrush="#1F000000"
                                            BorderThickness="1"
                                            CornerRadius="4">
                                            <TextBlock
                                                FontFamily="Consolas"
                                                FontSize="11"
                                                Foreground="#334155"
                                                Text="{Binding Display}"
                                                TextWrapping="Wrap"
                                                ToolTip="{Binding ArgumentsSummary}" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Grid>
            </DataTemplate>
        </templateSelector:MessageTemplateSelector.AnswerDataTemplate>
        <templateSelector:MessageTemplateSelector.ActionAnswerDataTemplate>
            <DataTemplate DataType="model:ActionAnswerMessage">
                <Grid Margin="8,6,40,6" HorizontalAlignment="Left">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="28" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Image
                        Width="22"
                        Height="22"
                        VerticalAlignment="Top"
                        Source="{StaticResource CopilotDrawingImage}" />
                    <Border
                        Grid.Column="1"
                        Margin="6,0,0,0"
                        Padding="10,8"
                        Background="White"
                        BorderBrush="#19000000"
                        BorderThickness="1"
                        CornerRadius="12,12,12,2">
                        <StackPanel>
                            <TextBlock
                                FontSize="13"
                                Text="{Binding Content}"
                                TextWrapping="Wrap" />
                            <TreeView
                                Margin="0,6,0,0"
                                BorderThickness="0"
                                Background="Transparent"
                                ItemsSource="{Binding PlanModel.ExecuteSkills}">
                                <TreeView.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock
                                            FontSize="12"
                                            Foreground="#333"
                                            Text="{Binding SkillName}"
                                            ToolTip="{Binding Description}" />
                                    </DataTemplate>
                                </TreeView.ItemTemplate>
                            </TreeView>
                        </StackPanel>
                    </Border>
                </Grid>
            </DataTemplate>
        </templateSelector:MessageTemplateSelector.ActionAnswerDataTemplate>
        <templateSelector:MessageTemplateSelector.ErrorDataTemplate>
            <DataTemplate DataType="model:ErrorMessage">
                <Border
                    Margin="8,6"
                    Padding="10,8"
                    Background="#FEF2F2"
                    BorderBrush="#FCA5A5"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon
                            Margin="0,0,8,0"
                            VerticalAlignment="Top"
                            Foreground="#B91C1C"
                            Symbol="ErrorCircle24" />
                        <TextBlock
                            FontSize="13"
                            Foreground="#B91C1C"
                            Text="{Binding Content}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </DataTemplate>
        </templateSelector:MessageTemplateSelector.ErrorDataTemplate>
    </templateSelector:MessageTemplateSelector>

</ResourceDictionary>