<Window
    x:Class="Copilot.Sw.Views.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Copilot.Sw.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:viewmodels="clr-namespace:Copilot.Sw.ViewModels"
    Name="window"
    Title="Settings"
    Width="640"
    Height="520"
    d:DataContext="{d:DesignInstance Type=viewmodels:SettingsWindowViewModel}"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Light" />
                <ui:ControlsDictionary />
                <ResourceDictionary Source="/Copilot.Sw;component/Themes/Icons.xaml" />
                <ResourceDictionary Source="/Copilot.Sw;component/TemplateSelector/MessageTemplateSelector.xaml" />
                <ResourceDictionary Source="/Copilot.Sw;component/Themes/Colors.xaml" />
                <ResourceDictionary Source="/Copilot.Sw;component/Themes/Converters.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="50" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock
                FontSize="20"
                FontWeight="SemiBold"
                Text="Sign in with GitHub" />
            <TextBlock
                Margin="0,4,0,16"
                TextWrapping="Wrap"
                Text="This add-in talks to GitHub Models. Sign in with your GitHub account using the device flow — no token pasting required." />

            <!-- Model picker -->
            <Grid Margin="0,4,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <TextBlock
                    VerticalAlignment="Center"
                    Margin="0,0,8,0"
                    FontWeight="SemiBold"
                    Text="Model:" />
                <ComboBox
                    Grid.Column="1"
                    IsEditable="True"
                    ItemsSource="{Binding GitHubModelPresets}"
                    Text="{Binding GitHubModel, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>

            <!-- Idle state: Sign-in button -->
            <StackPanel
                Orientation="Horizontal"
                Margin="0,8,0,8"
                Visibility="{Binding IsAwaitingDeviceCode, Converter={StaticResource InvertBoolToVisibilityConverter}}">
                <ui:Button
                    Appearance="Primary"
                    Command="{Binding SignInWithGitHubCommand}"
                    Content="Sign in with GitHub"
                    Icon="PersonAccounts24"
                    IsEnabled="{Binding IsSigningIn, Converter={StaticResource InvertBoolConverter}}" />
                <ui:Button
                    Margin="8,0,0,0"
                    Appearance="Secondary"
                    Command="{Binding SignOutCommand}"
                    Content="Sign out"
                    Icon="SignOut24"
                    Visibility="{Binding IsSignedIn, Converter={StaticResource BoolToVisibilityConverter}}" />
            </StackPanel>

            <!-- Awaiting state: device code + verification URL + cancel -->
            <Border
                Margin="0,8,0,8"
                Padding="12"
                BorderBrush="#CCCCCC"
                BorderThickness="1"
                CornerRadius="6"
                Visibility="{Binding IsAwaitingDeviceCode, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock
                        FontWeight="SemiBold"
                        Text="1. Open the verification page" />
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,8">
                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="Consolas"
                            Text="{Binding DeviceVerificationUri}" />
                        <ui:Button
                            Margin="8,0,0,0"
                            Appearance="Secondary"
                            Command="{Binding OpenVerificationUriCommand}"
                            Content="Open in browser"
                            Icon="Open24" />
                    </StackPanel>

                    <TextBlock
                        FontWeight="SemiBold"
                        Text="2. Enter this code" />
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,8">
                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="Consolas"
                            FontSize="20"
                            FontWeight="Bold"
                            Text="{Binding DeviceUserCode}" />
                        <ui:Button
                            Margin="12,0,0,0"
                            Appearance="Secondary"
                            Command="{Binding CopyDeviceCodeCommand}"
                            Content="Copy"
                            Icon="Copy24" />
                    </StackPanel>

                    <TextBlock
                        Margin="0,4,0,8"
                        FontStyle="Italic"
                        Text="Waiting for you to approve sign-in on GitHub…"
                        TextWrapping="Wrap" />

                    <ui:Button
                        HorizontalAlignment="Left"
                        Appearance="Secondary"
                        Command="{Binding CancelSignInCommand}"
                        Content="Cancel"
                        Icon="Dismiss24" />
                </StackPanel>
            </Border>

            <!-- Status line (shared) -->
            <TextBlock
                Margin="0,8,0,0"
                Text="{Binding GitHubStatus}"
                TextWrapping="Wrap" />

            <!-- Signed-in indicator -->
            <TextBlock
                Margin="0,8,0,0"
                FontStyle="Italic"
                Foreground="#188038"
                Text="{Binding SignedInIdentity}"
                TextWrapping="Wrap"
                Visibility="{Binding IsSignedIn, Converter={StaticResource BoolToVisibilityConverter}}" />
        </StackPanel>

        <!-- Buttons row -->
        <Grid Grid.Row="1">
            <ui:Button
                Margin="0,0,120,0"
                HorizontalAlignment="Right"
                Appearance="Primary"
                Command="{Binding OkCommand}"
                CommandParameter="{Binding ElementName=window}"
                Content="Ok(_O)"
                Icon="Checkmark28" />
            <ui:Button
                Margin="5"
                HorizontalAlignment="Right"
                Content="Cancel(_C)"
                IsCancel="True" />
        </Grid>
    </Grid>
</Window>
