<UserControl
    x:Class="Copilot.Sw.WPFChatPane"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Copilot.Sw.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Copilot.Sw"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:md="https://github.com/fantasticfiasco/mvvm-dialogs"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:viewmodels="clr-namespace:Copilot.Sw.ViewModels"
    d:DataContext="{d:DesignInstance Type=viewmodels:WPFChatPaneViewModel}"
    d:DesignHeight="700"
    d:DesignWidth="300"
    md:DialogServiceViews.IsRegistered="True"
    Background="#F7F9FB"
    FontFamily="{x:Static SystemFonts.CaptionFontFamily}"
    mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Light" />
                <ui:ControlsDictionary />
                <ResourceDictionary Source="/Copilot.Sw;component/Themes/Icons.xaml" />
                <ResourceDictionary Source="/Copilot.Sw;component/TemplateSelector/MessageTemplateSelector.xaml" />
                <ResourceDictionary Source="/Copilot.Sw;component/Themes/Colors.xaml" />
                <ResourceDictionary Source="/Copilot.Sw;component/Themes/Converters.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header strip: logo + title + model badge + settings -->
        <Border
            Background="White"
            BorderBrush="#19000000"
            BorderThickness="0,0,0,1">
            <Grid Margin="10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Image
                    Grid.Column="0"
                    Width="20"
                    Height="20"
                    VerticalAlignment="Center"
                    Source="/Copilot.Sw;component/Assets/Icons/SolidWorksCopilot.png" />
                <TextBlock
                    Grid.Column="1"
                    Margin="8,0,0,0"
                    VerticalAlignment="Center"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Text="SolidWorks Copilot" />
                <Border
                    Grid.Column="3"
                    Margin="0,0,6,0"
                    Padding="6,2"
                    VerticalAlignment="Center"
                    Background="#F0F2F5"
                    CornerRadius="8"
                    ToolTip="Active model"
                    Visibility="Collapsed">
                    <TextBlock
                        FontSize="11"
                        Foreground="#444"
                        Text="{Binding CurrentModel}" />
                </Border>
                <Button
                    Grid.Column="4"
                    Padding="6"
                    Command="{Binding ClearConversationCommand}"
                    IsEnabled="{Binding HasItem}"
                    ToolTip="New conversation">
                    <ui:SymbolIcon Symbol="ChatAdd24" />
                </Button>
                <ToggleButton
                    Grid.Column="2"
                    Margin="0,0,6,0"
                    Padding="6,2"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    IsChecked="{Binding IsDryRun, Mode=TwoWay}"
                    ToolTip="Dry-run mode: model produces a plan without invoking tools."
                    Background="Transparent"
                    BorderBrush="#1F000000">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Margin="0,0,4,0" Symbol="Beaker24" />
                        <TextBlock FontSize="11" Text="Dry-run" VerticalAlignment="Center" />
                    </StackPanel>
                </ToggleButton>
                <Button
                    Grid.Column="5"
                    Padding="6"
                    Command="{Binding OpenSettingsCommand}"
                    ToolTip="Settings">
                    <ui:SymbolIcon Symbol="Settings28" />
                </Button>
            </Grid>
        </Border>
        <DockPanel Grid.Row="1" LastChildFill="True">
            <Border
                Margin="6,4,6,6"
                BorderBrush="#19000000"
                BorderThickness="1"
                CornerRadius="12"
                DockPanel.Dock="Bottom">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="44" />
                        <ColumnDefinition />
                        <ColumnDefinition Width="44" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <ToggleButton
                        Name="SkillsToggleBtn"
                        Margin="4"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        ToolTip="Skills">
                        <ui:SymbolIcon Symbol="TableSwitch24" />
                    </ToggleButton>
                    <Popup
                        Margin="5,10"
                        AllowsTransparency="True"
                        IsOpen="{Binding ElementName=SkillsToggleBtn, Path=IsChecked}"
                        Placement="Top"
                        PlacementTarget="{Binding ElementName=SkillsToggleBtn}"
                        PopupAnimation="Fade"
                        StaysOpen="False">
                        <Border
                            Background="White"
                            BorderBrush="#19000000"
                            BorderThickness="1"
                            CornerRadius="5">
                            <ListBox
                                Margin="10"
                                ItemsSource="{Binding Skills}"
                                SelectedItem="{Binding SelectedSkill}" />
                        </Border>
                    </Popup>
                    <Grid Grid.Column="1">
                        <TextBox
                            x:Name="QuestionBox"
                            MinHeight="32"
                            MaxHeight="160"
                            Margin="0,6"
                            VerticalAlignment="Stretch"
                            VerticalContentAlignment="Center"
                            AcceptsReturn="True"
                            Background="Transparent"
                            BorderThickness="0"
                            Style="{DynamicResource DefaultTextBoxStyle}"
                            Text="{Binding Question, UpdateSourceTrigger=PropertyChanged}"
                            TextWrapping="Wrap"
                            VerticalScrollBarVisibility="Auto">
                            <TextBox.InputBindings>
                                <KeyBinding
                                    Key="Enter"
                                    Command="{Binding SendCommand}"
                                    Modifiers="Ctrl" />
                            </TextBox.InputBindings>
                        </TextBox>
                        <TextBlock
                            Margin="6,0"
                            VerticalAlignment="Center"
                            Foreground="#9AA0A6"
                            IsHitTestVisible="False"
                            Text="Ask Copilot to draw, model, or explain… (Ctrl+Enter)">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=QuestionBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                    <ui:Button
                        Grid.Column="2"
                        Margin="4"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Appearance="Primary"
                        Command="{Binding SendCommand}"
                        ToolTip="Send (Ctrl+Enter)">
                        <ui:SymbolIcon Symbol="Send20" />
                    </ui:Button>

                    <!-- Inline model picker: like VS Code Copilot, the active
                         model is shown right under the input where the user
                         can switch it without opening Settings. -->
                    <Border
                        Grid.Row="1"
                        Grid.ColumnSpan="3"
                        Margin="6,0,6,4"
                        Padding="0"
                        Background="Transparent"
                        Visibility="{Binding IsConfigured, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="2,0,6,0"
                                VerticalAlignment="Center"
                                FontSize="11"
                                Foreground="#888"
                                Text="Model:" />
                            <ComboBox
                                MinWidth="180"
                                MaxWidth="260"
                                FontSize="11"
                                ItemsSource="{Binding AvailableModels}"
                                SelectedItem="{Binding SelectedModel}"
                                ToolTip="Switch the GitHub Models chat model" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
            <Grid DockPanel.Dock="Top">
                <ScrollViewer x:Name="ChatScroll" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemTemplateSelector="{StaticResource MessageTemplateSelector}" ItemsSource="{Binding Conversation.Messages}" />
                </ScrollViewer>
                <Button
                    Width="50"
                    Margin="0,12"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    ToolTip="Stop"
                    Visibility="{Binding SendCommand.IsRunning, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ui:SymbolIcon Symbol="Stop24" />
                </Button>
                <ProgressBar
                    VerticalAlignment="Bottom"
                    IsIndeterminate="True"
                    Visibility="{Binding SendCommand.IsRunning, Converter={StaticResource BoolToVisibilityConverter}}" />
            </Grid>
        </DockPanel>

        <!-- Empty state: not signed in / no provider configured -->
        <Grid
            Grid.Row="1"
            Margin="20,0,20,140"
            VerticalAlignment="Center">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding IsConfigured}" Value="False" />
                                <Condition Binding="{Binding IsInitializing}" Value="False" />
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Visibility" Value="Visible" />
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Image
                    Width="64"
                    Height="64"
                    Source="/Copilot.Sw;component/Assets/Icons/SolidWorksCopilot.png" />
                <TextBlock
                    Margin="0,16,0,4"
                    HorizontalAlignment="Center"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Text="Welcome to SolidWorks Copilot" />
                <TextBlock
                    Margin="0,0,0,20"
                    HorizontalAlignment="Center"
                    Foreground="#666"
                    Text="Sign in to start chatting and modelling."
                    TextAlignment="Center"
                    TextWrapping="Wrap" />
                <ui:Button
                    Padding="14,8"
                    HorizontalAlignment="Center"
                    Appearance="Primary"
                    Command="{Binding OpenSettingsCommand}"
                    Content="Sign in with GitHub" />
            </StackPanel>
        </Grid>

        <!-- Empty state: signed in, no conversation yet -->
        <StackPanel
            Grid.Row="1"
            Margin="20,40,20,140"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding IsConfigured}" Value="True" />
                                <Condition Binding="{Binding HasItem}" Value="False" />
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Visibility" Value="Visible" />
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>
            <Image
                Width="56"
                Height="56"
                Source="/Copilot.Sw;component/Assets/Icons/SolidWorksCopilot.png" />
            <TextBlock
                Margin="0,16,0,4"
                HorizontalAlignment="Center"
                FontSize="15"
                FontWeight="SemiBold"
                Text="How can I help with your model?" />
            <TextBlock
                Margin="0,0,0,16"
                HorizontalAlignment="Center"
                Foreground="#666"
                Text="Ask me to sketch, create features, or explain part geometry."
                TextAlignment="Center"
                TextWrapping="Wrap" />
            <TextBlock
                Margin="4,0,4,6"
                HorizontalAlignment="Center"
                FontSize="11"
                Foreground="#888"
                Text="Try one of these:" />
            <ItemsControl>
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Center" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.Resources>
                    <Style x:Key="StarterChipStyle" TargetType="Button">
                        <Setter Property="Margin" Value="4" />
                        <Setter Property="Padding" Value="10,6" />
                        <Setter Property="Background" Value="White" />
                        <Setter Property="BorderBrush" Value="#19000000" />
                        <Setter Property="BorderThickness" Value="1" />
                        <Setter Property="Cursor" Value="Hand" />
                        <Setter Property="Command" Value="{Binding DataContext.UsePromptCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                        <Setter Property="CommandParameter" Value="{Binding Content, RelativeSource={RelativeSource Self}}" />
                    </Style>
                </ItemsControl.Resources>
                <Button Style="{StaticResource StarterChipStyle}" Content="Create a new part document" />
                <Button Style="{StaticResource StarterChipStyle}" Content="Sketch a 50mm circle on the front plane" />
                <Button Style="{StaticResource StarterChipStyle}" Content="Draw a 100x40 rectangle" />
                <Button Style="{StaticResource StarterChipStyle}" Content="What skills do you have?" />
            </ItemsControl>
        </StackPanel>
    </Grid>
</UserControl>
